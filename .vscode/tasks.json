{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "owner": "next",
        "pattern": [
          {
            "regexp": "^$",
            "file": 1,
            "line": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting.*",
          "endsPattern": ".*Ready in.*"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "detail": "Inicia o servidor Next.js (http://localhost:3000). Depois abra o Simple Browser pra ver inline no Cursor."
    },
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "detail": "Roda npm run build pra validar zero erros TS/Tailwind."
    }
  ]
}
